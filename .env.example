# TTA.dev Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================================
# Free Flagship Model API Keys
# ============================================================================

# Google AI Studio (Gemini Pro & Flash) - FREE
# Get your key: https://aistudio.google.com/
# Free tier: 1500 RPD, no credit card required
GOOGLE_API_KEY=your-google-ai-studio-key-here

# OpenRouter (DeepSeek R1, Qwen) - FREE
# Get your key: https://openrouter.ai/
# Free tier: Daily limits reset at midnight UTC, no credit card required
OPENROUTER_API_KEY=your-openrouter-key-here

# Groq (Llama 3.3 70B, Mixtral) - FREE
# Get your key: https://console.groq.com/
# Free tier: 250-14,400 RPD per model (varies), no credit card required
GROQ_API_KEY=your-groq-key-here

# Rate limits sourced from: https://github.com/cheahjs/free-llm-api-resources (April 2026)

# Cerebras (Llama 3.1 8B, GPT-OSS 120B) - FREE
# Get your key: https://cloud.cerebras.ai/
# Free tier: 14,400 RPD, 1M tokens/day, no credit card required
# OpenAI-compatible endpoint: https://api.cerebras.ai/v1
CEREBRAS_API_KEY=your-cerebras-key-here

# Cohere (Command A, Command R+) - FREE
# Get your key: https://dashboard.cohere.com/api-keys
# Free tier: 20 RPM, 1,000 req/month shared quota, no credit card required
COHERE_API_KEY=your-cohere-key-here

# NVIDIA NIM (various open models) - FREE
# Get your key: https://build.nvidia.com/
# Free tier: 40 RPM, phone verification required
# OpenAI-compatible endpoint: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your-nvidia-nim-key-here

# Mistral (open models) - FREE (experiment plan)
# Get your key: https://console.mistral.ai/
# Free tier: 1 req/sec, 500K TPM, 1B tokens/month — requires phone verification + data training opt-in
MISTRAL_API_KEY=your-mistral-key-here

# GitHub Models (GPT-5, o3, Llama 4, Grok 3, DeepSeek) - FREE with GitHub account
# Uses your existing GITHUB_TOKEN — no separate signup needed
# Free tier: 50-150 RPD depending on model size (Copilot Free tier)
# Endpoint: https://models.inference.ai.azure.com
GITHUB_TOKEN=your-github-token-here

# Hugging Face (thousands of models) - FREE
# Get your token: https://huggingface.co/settings/tokens
# Free tier: 300 requests/hour, no credit card required
HF_TOKEN=your-huggingface-token-here

# Together.ai (Llama 4 Scout) - $25 FREE CREDITS
# Get your key: https://www.together.ai/
# Free credits: $25 for new users, credit card required
TOGETHER_API_KEY=your-together-key-here

# ============================================================================
# Paid Model API Keys (Optional)
# ============================================================================

# OpenAI (GPT-4o, GPT-4o-mini)
# Get your key: https://platform.openai.com/api-keys
# Pricing: $0.15-$10.00 per 1M tokens
OPENAI_API_KEY=your-openai-key-here

# Anthropic (Claude Sonnet, Opus)
# Get your key: https://console.anthropic.com/
# Pricing: $3.00-$75.00 per 1M tokens
ANTHROPIC_API_KEY=your-anthropic-key-here

# ============================================================================
# Benchmark & Evaluation API Keys (Optional)
# ============================================================================

# Artificial Analysis — live benchmark data (intelligence, speed, price indices)
# Get your key: https://artificialanalysis.ai/
# Provides: aa_intelligence, aa_coding, aa_math, aa_speed_tok_per_sec, aa_ttft_seconds,
#           aa_price_per_1m_input, and per-eval scores (mmlu_pro, gpqa, livecodebench, …)
# Refresh: uv run python -m ttadev.primitives.llm.benchmark_fetcher [--force]
# Cache:   ~/.cache/ttadev/benchmark_data.json  (24-hour TTL)
ARTIFICIAL_ANALYSIS_API_KEY=your-aa-key-here

# ============================================================================
# Database API Keys (Optional)
# ============================================================================

# Supabase (Cloud PostgreSQL)
# Get your keys: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your-supabase-url-here
SUPABASE_KEY=your-supabase-anon-key-here

# ============================================================================
# MCP Server Integration (Optional)
# ============================================================================

# GitHub Personal Access Token (for GitHub MCP Server)
# Get your token: https://github.com/settings/tokens
# Required scopes: repo, org, project (read/write access)
GITHUB_TOKEN=your-github-personal-access-token-here

# Logseq API Token (for Logseq MCP Server)
# Setup:
# 1. Enable Developer mode in Logseq: Settings → Advanced → Developer mode
# 2. Enable HTTP APIs: Settings → Features → "Enable HTTP APIs server"
# 3. Restart Logseq
# 4. Start API server: Click API button (🔌) → "Start server"
# 5. Generate token: API panel → "Authorization" → "Add"
LOGSEQ_API_TOKEN=your-logseq-api-token-here
LOGSEQ_API_URL=http://127.0.0.1:12315

# ============================================================================
# Observability (Optional)
# ============================================================================

# OpenTelemetry Exporter Endpoint
# For local development, use: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service Name for Observability
OTEL_SERVICE_NAME=tta-dev-app

# ============================================================================
# Notes
# ============================================================================

# 1. Never commit .env file to version control
# 2. Add .env to .gitignore
# 3. Use environment-specific .env files (.env.dev, .env.prod)
# 4. Rotate API keys regularly for security
# 5. Monitor usage to avoid hitting rate limits

# ============================================================================
# Quick Start Guide
# ============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. Fill in your API keys (start with free ones):
#    - Google AI Studio (best free flagship model)
#    - OpenRouter (DeepSeek R1, on par with OpenAI o1)
#    - Groq (ultra-fast inference)

# 3. Test your setup:
#    cd packages/tta-dev-primitives
#    uv run python examples/free_flagship_models.py

# 4. Verify free tier access:
#    - Google AI Studio: 1500 RPD
#    - OpenRouter: Daily limits reset at midnight UTC
#    - Groq: 250-14,400 RPD per model (varies)

# 5. Monitor usage:
#    - Check provider dashboards for usage stats
#    - Set up alerts before hitting limits
#    - Use fallback chain for 100% uptime
