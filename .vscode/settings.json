{
    "python.defaultInterpreterPath": "/workspaces/TTA.dev/.venv/bin/python",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticMode": "workspace",
    "ruff.nativeServer": true,
    "ruff.configuration": "./pyproject.toml",
    "ruff.lineLength": 88,
    "ruff.fixAll": true,
    "ruff.organizeImports": true,
    "ruff.codeAction.fixViolation": {
        "enable": true
    },
    "ruff.codeAction.disableRuleComment": {
        "enable": true
    },
    "pyright.disableTypeCheck": false,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll.ruff": "explicit"
    },
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.profiles.linux": {
        "zsh": {
            "path": "/usr/bin/zsh"
        }
    },
    "mcp.servers": {
        "tta-notes-kb": {
            "command": "python",
            "args": ["/home/thein/repos/TTA-notes/mcp_server.py"],
            "env": {},
            "description": "TTA-notes KB — search_kb, get_high_priority_todos",
            "disabled": false
        },
        "tta-dev": {
            "command": "uv",
            "args": [
                "run",
                "python",
                "-m",
                "ttadev.primitives.mcp_server"
            ],
            "env": {},
            "description": "TTA.dev Primitives - Code analysis and primitive recommendations",
            "disabled": false
        }
    }
}
