{
  "include": [
    "ttadev"
  ],
  "exclude": [
    "ttadev/skills/tests",
    "ttadev/skills/src",
    "ttadev/observability/apm/langfuse",
    "ttadev/primitives/integrations/anthropic_primitive.py",
    "ttadev/primitives/integrations/google_ai_studio_primitive.py",
    "ttadev/primitives/integrations/supabase_primitive.py",
    "ttadev/primitives/integrations/sqlite_primitive.py",
    "ttadev/primitives/integrations/ollama_primitive.py",
    "ttadev/primitives/integrations/openai_primitive.py",
    "ttadev/primitives/ace/llm_integration.py",
    "ttadev/primitives/apm/setup.py",
    "ttadev/primitives/observability/prometheus_exporter.py",
    "ttadev/primitives/observability/prometheus_metrics.py",
    "ttadev/observability/observability_integration/apm_setup.py",
    "ttadev/observability/websocket_handler.py",
    "ttadev/integrations",
    "**/__pycache__",
    "**/*.pyc",
    "**/node_modules",
    "**/.venv",
    "**/venv"
  ],
  "extraPaths": [
    ".venv/lib/python3.14/site-packages"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic"
}
